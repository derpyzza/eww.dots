(include "variables.yuck")
(include "widgets.yuck")

(defwindow bar
          :monitor 0
          :geometry (geometry 
                      :x "0px"
                      :y "0px"
                      :width "2%"
                      :height "100%"
                      :anchor "center left")
          :reserve (struts :distance "2%" :side "left")
          :stacking "fg"
          :windowtype "dock"
          :wm-ignore "false"
      (bar))
