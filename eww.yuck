(include "variables.yuck")
(include "widgets.yuck")

(defwindow bar
          :monitor 0
          :geometry (geometry 
                      :x "0px"
                      :y "0px"
                      :width "45px"
                      :height "100%"
                      :anchor "center right")
          :reserve (struts :distance "45px" :side "right")
          :stacking "bottom"
          :windowtype "dock"
          :wm-ignore "false"
      (bar))
