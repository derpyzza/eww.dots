(include "variables.yuck")
(include "widgets.yuck")

(defwindow bar
          :monitor 0
          :geometry (geometry 
                      :x "0px"
                      :y "0px"
                      :width "100%"
                      :height "3%"
                      :anchor "top center")
          :reserve (struts :distance "3%" :side "top")
          :stacking "bottom"
          :windowtype "dock"
          :wm-ignore "false"
      (bar))

(defwindow 
  calendar :monitor 0
           :geometry (geometry :anchor "bottom right" :x "-60px" :y "-5px" :height "60px" :width "60px")
           :stacking "fg"
           :windowtype "dock"
           :wm-ignore "true"
  (calendar))
